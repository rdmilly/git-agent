# Dockerfile.mcp — FastMCP wrapper for git-agent
#
# Separate lightweight image that speaks MCP over streamable-http on port 9094.
# Proxies tool calls to the main git-agent REST backend at http://git-agent:9093.
# Same pattern Helix uses: helix-cortex (REST) + helix-mcp (FastMCP wrapper).
#
# Published to ghcr.io/rdmilly/git-agent-mcp on every push to main.

FROM python:3.12-slim

WORKDIR /app

# Install only mcp + httpx — no git, no gh, no fastapi needed here.
RUN pip install --no-cache-dir 'mcp[cli]>=1.6.0' 'httpx>=0.27.0'

COPY mcp_server.py .

EXPOSE 9094

ENV GIT_AGENT_URL=http://git-agent:9093 \
    PORT=9094 \
    PYTHONUNBUFFERED=1

CMD ["python", "mcp_server.py"]
